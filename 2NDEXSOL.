  #include<stdio.h>

int main()

{
   int num, original, sum = 0, digit;

    printf("Enter a 5-digit number: ");
    scanf("%d", &num);

    original = num;

    while (num != 0) {
        digit = num % 10;
        sum += digit;
        num /= 10;
    }

    printf("Sum of digits of %d is %d\n", original, sum);
    return 0;
}

  
