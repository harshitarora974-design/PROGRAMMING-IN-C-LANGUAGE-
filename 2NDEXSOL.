{
  int num, reversed = 0, digit;

  printf("Enter a 5-digit number: ");
  scanf("%d", &num);

   while (num != 0) 
{
      digit = num % 10;                    // Extract last digit
      reversed = reversed * 10 + digit;    // Add digit to reversed
      num /= 10;                           // Remove last digit
  }

  printf("Reversed number: %d\n", reversed);

   return 0;
}


